# Identifiants générés sur https://piste.gouv.fr (application avec l'API Légifrance souscrite)
# Copier ce fichier en .env et remplir les valeurs
PISTE_CLIENT_ID=votre_client_id
PISTE_CLIENT_SECRET=votre_client_secret
# prod par défaut ; mettre "sandbox" pour l'environnement de test
# PISTE_ENV=sandbox

# Clé API Mistral (gratuite, plan Experiment) : https://console.mistral.ai → API Keys
MISTRAL_API_KEY=votre_cle_mistral
# MISTRAL_MODEL=mistral-small-latest
