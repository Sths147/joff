# Credentials generated on https://piste.gouv.fr (application subscribed to the Légifrance API)
# Copy this file to .env and fill in the values
PISTE_CLIENT_ID=your_client_id
PISTE_CLIENT_SECRET=your_client_secret
# prod by default; set to "sandbox" for the test environment
# PISTE_ENV=sandbox

# Mistral API key (free, Experiment plan): https://console.mistral.ai → API Keys
MISTRAL_API_KEY=your_mistral_key
# MISTRAL_MODEL=mistral-small-latest

# MongoDB connection string, used to track which JO editions have already
# been downloaded (keyed by publication date). docker-compose overrides this
# to mongodb://mongo:27017 to reach the mongo service; the default below is
# for running the backend directly against a local MongoDB.
# MONGO_URI=mongodb://localhost:27017

# Password for the "joff" Postgres user (accounts/login). docker-compose creates
# the postgres service with this password and passes it to the backend via
# DATABASE_URL; also used directly if you run the backend against a local Postgres.
POSTGRES_PASSWORD=change_me

# Secret used to sign session JWTs. Generate one with: openssl rand -hex 32
JWT_SECRET=change_me

# Shared secret letting the cron container trigger the daily JO fetch without
# a user login (see cron/crontab). Generate one with: openssl rand -hex 32
CRON_TOKEN=change_me
