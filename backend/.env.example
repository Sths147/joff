# Credentials generated on https://piste.gouv.fr (application subscribed to the Légifrance API)
# Copy this file to .env and fill in the values
PISTE_CLIENT_ID=your_client_id
PISTE_CLIENT_SECRET=your_client_secret
# prod by default; set to "sandbox" for the test environment
# PISTE_ENV=sandbox

# Mistral API key (free, Experiment plan): https://console.mistral.ai → API Keys
MISTRAL_API_KEY=your_mistral_key
# MISTRAL_MODEL=mistral-small-latest

# MongoDB connection string, used to track which JO editions have already
# been downloaded (keyed by publication date). docker-compose overrides this
# to mongodb://mongo:27017 to reach the mongo service; the default below is
# for running the backend directly against a local MongoDB.
# MONGO_URI=mongodb://localhost:27017
